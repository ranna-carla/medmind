rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários — qualquer autenticado pode ler (ranking), escreve apenas o próprio
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Módulos gerados pela IA
    match /generatedModules/{docId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Ranking (leitura pública entre autenticados)
    match /ranking/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == docId;
    }
  }
}
