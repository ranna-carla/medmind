rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin tem acesso total a tudo
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ranna@grupolead.com.br';
    }

    // Usuários — qualquer autenticado pode ler; escreve no próprio;
    // permite atualizar campo 'friends' de outro usuário (aceitar/remover amizade)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null
        && (request.auth.uid == userId
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
            || isAdmin());
    }

    // Revisões do usuário (subcoleção)
    match /users/{userId}/revisions/{revId} {
      allow read, create, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Flashcard decks do usuário (subcoleção)
    match /users/{userId}/flashdecks/{deckId} {
      allow read, create, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Módulos gerados pela IA
    match /generatedModules/{docId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Ranking (leitura pública entre autenticados)
    match /ranking/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == docId || isAdmin());
    }

    // Solicitações de amizade
    match /friendRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to || isAdmin());
      allow delete: if isAdmin();
    }

    // Desafios — participantes e convidados podem ler/escrever
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.participantIds
            || request.auth.uid in resource.data.invited
            || request.auth.uid == resource.data.creatorId
            || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.creatorId || isAdmin());

      // Mensagens do chat do desafio
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // Revisões de estudo
    match /revisions/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Decks de flashcards salvos
    match /flashdecks/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Sugestões
    match /suggestions/{docId} {
      allow read, create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Duelos 1v1
    match /duels/{duelId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.creatorId
            || request.auth.uid == resource.data.opponentId
            || resource.data.opponentId == null
            || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.creatorId || isAdmin());
    }

    // Desafio Diário
    match /dailyChallenge/{dateId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }

    // Módulos curados (curadoria) — admin gerencia, todos leem
    match /curatedModules/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
  }
}
